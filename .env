# Application
APP_NAME=sysDock
APP_VERSION=1.0.0
DEBUG=False

# Security
SECRET_KEY=sysdock-secret-key   # Change this to yopur custom secret key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database
POSTGRES_USER=sysDock-pg-user
POSTGRES_PASSWORD=sysDock-pg-pass   # Change this to yopur custom password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=sysDock-pg-db

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# Docker
DOCKER_HOST=

# CORS
BACKEND_CORS_ORIGINS=["http://localhost"]
